# Copy to .env and edit. Loaded via your process manager / docker, not by the app itself.

# Require "Authorization: Bearer <API_KEY>" on requests. Leave unset to disable auth.
API_KEY=sk-local-changeme

# Base URL clients use to reach this service (used when response_format=url).
PUBLIC_BASE=http://your-gpu-server:8000

# Model + precision. Use float16 if bfloat16 is unstable on your GPU.
MODEL_ID=Tongyi-MAI/Z-Image-Turbo
DTYPE=bfloat16

# Name advertised via /v1/models and expected as the request "model" field.
MODEL_NAME=z-image-turbo

# Quantization: "none" or "fp8".
# fp8 = torchao float8 weight-only (~6GB, fully on-GPU). RECOMMENDED for 10GB cards.
# Requires torchao (in requirements.txt). When fp8, CPU_OFFLOAD is ignored.
QUANTIZATION=fp8

# Stream weights to GPU on demand. Used only when QUANTIZATION=none.
# Keep "1" for ~10GB cards running bf16/fp16; set "0" if you have >=16GB.
CPU_OFFLOAD=1

# url-mode generated images: storage dir + how long to keep them (seconds).
IMG_DIR=images
IMG_TTL_SECONDS=3600

# GPU queue: max requests in flight (1 running + waiters). Beyond this -> HTTP 429.
# Retry-After is the seconds hint sent with the 429.
MAX_QUEUE=8
RETRY_AFTER=10
